rules_version = '2';

// Reglas de seguridad de Firestore · Copones Buena Vista
// Cómo aplicarlas: ver SEGURIDAD.md en este repo.
service cloud.firestore {
  match /databases/{database}/documents {

    // Dueños de la app (siempre admins, pase lo que pase con la colección admins)
    function esDueno() {
      return request.auth != null
        && request.auth.token.email in [
          'miguelippolito3@gmail.com',
          'miguel.ippolito@grupomitre.com.ar'
        ];
    }

    // Admin = dueño o co-admin dado de alta en la colección admins
    function esAdmin() {
      return esDueno()
        || (request.auth != null
            && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // 📊 Los datos de la app (ranking, fechas, jugadores)
    // Todos pueden leer (la app funciona sin login y el backup semanal también lee de acá).
    // Solo los admins pueden escribir.
    match /app/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // 👤 Usuarios logueados: cada uno escribe SOLO su propio documento.
    // Los admins pueden ver la lista completa (panel de usuarios).
    match /usuarios/{uid} {
      allow read: if esAdmin() || (request.auth != null && request.auth.uid == uid);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 👑 Co-admins: solo los dueños los agregan o quitan.
    // Cada usuario puede consultar su propio documento (para saber si es co-admin).
    match /admins/{email} {
      allow get: if request.auth != null && (request.auth.token.email == email || esAdmin());
      allow list: if esAdmin();
      allow write: if esDueno();
    }

    // 📝 Propuestas de resultados: cualquier usuario logueado puede CREAR una,
    // pero nadie puede editar la de otro (no se pisan entre sí) y
    // solo los admins las leen, confirman y borran.
    match /propuestas/{id} {
      allow create: if request.auth != null;
      allow update: if false;
      allow read, delete: if esAdmin();
    }

    // Todo lo que no está listado arriba: prohibido.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
